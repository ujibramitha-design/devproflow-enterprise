    "integration_systems": [
      {
        "system_id": "supabase_database",
        "name": "Supabase Database Integration",
        "enabled": true,
        "status": "ACTIVE",
        "priority": "HIGH",
        "description": "Primary database for KPRFlow Enterprise",
        "api_endpoints": [
          {
            "endpoint_id": "supabase_auth",
            "method": "POST",
            "internal_path": "/api/auth",
            "external_url": "https://your-project.supabase.co/auth/v1",
            "purpose": "User authentication",
            "data_mapping": {
              "request": {
                "email": "email",
                "password": "password",
                "provider": "provider"
              },
              "response": {
                "access_token": "access_token",
                "refresh_token": "refresh_token",
                "user": "user_data"
              }
            },
            "authentication": {
              "type": "api_key",
              "header": "apikey",
              "key": "SUPABASE_ANON_KEY"
            }
          },
          {
            "endpoint_id": "supabase_rest_customers",
            "method": "GET",
            "internal_path": "/api/customers",
            "external_url": "https://your-project.supabase.co/rest/v1/customers",
            "purpose": "Customer data operations",
            "data_mapping": {
              "request": {
                "select": "fields_to_select",
                "filter": "where_conditions",
                "order": "order_by"
              },
              "response": {
                "id": "customer_id",
                "name": "customer_name",
                "email": "customer_email",
                "phone": "customer_phone",
                "nik": "customer_nik",
                "birth_date": "customer_birth_date",
                "address": "customer_address",
                "created_at": "registration_date"
              }
            },
            "authentication": {
              "type": "bearer_token",
              "header": "Authorization",
              "key": "Bearer SUPABASE_ANON_KEY"
            }
          },
          {
            "endpoint_id": "supabase_rest_applications",
            "method": "POST",
            "internal_path": "/api/applications",
            "external_url": "https://your-project.supabase.co/rest/v1/applications",
            "purpose": "Application data operations",
            "data_mapping": {
              "request": {
                "customer_id": "customer_id",
                "property_id": "property_id",
                "application_date": "application_date",
                "status": "application_status",
                "loan_amount": "loan_amount",
                "down_payment": "down_payment",
                "tenure": "loan_tenure"
              },
              "response": {
                "id": "application_id",
                "customer_id": "customer_id",
                "property_id": "property_id",
                "application_date": "application_date",
                "status": "application_status",
                "loan_amount": "loan_amount",
                "down_payment": "down_payment",
                "tenure": "loan_tenure",
                "created_at": "created_timestamp"
              }
            },
            "authentication": {
              "type": "bearer_token",
              "header": "Authorization",
              "key": "Bearer SUPABASE_ANON_KEY"
            }
          },
          {
            "endpoint_id": "supabase_storage",
            "method": "POST",
            "internal_path": "/api/storage",
            "external_url": "https://your-project.supabase.co/storage/v1/object",
            "purpose": "File storage operations",
            "data_mapping": {
              "request": {
                "bucket": "storage_bucket",
                "path": "file_path",
                "file": "file_data"
              },
              "response": {
                "Key": "file_key",
                "ETag": "file_etag"
              }
            },
            "authentication": {
              "type": "bearer_token",
              "header": "Authorization",
              "key": "Bearer SUPABASE_ANON_KEY"
            }
          }
        ],
        "data_transformations": [
          {
            "transformation_id": "customer_data_transform",
            "description": "Transform customer data for Supabase",
            "input_format": "internal_customer_format",
            "output_format": "supabase_customer_format",
            "rules": [
              {
                "field": "phone",
                "rule": "format_phone_international",
                "input": "08123456789",
                "output": "+628123456789"
              },
              {
                "field": "birth_date",
                "rule": "format_date_iso",
                "input": "20-03-2001",
                "output": "2001-03-20"
              },
              {
                "field": "income",
                "rule": "parse_currency",
                "input": "Rp 10.000.000",
                "output": 10000000
              }
            ]
          }
        ],
        "error_handling": {
          "error_codes": {
            "400": "Bad Request - Invalid data format",
            "401": "Unauthorized - Invalid API key",
            "403": "Forbidden - Insufficient permissions",
            "404": "Not Found - Resource not found",
            "500": "Server Error - Database error"
          },
          "retry_logic": {
            "max_retries": 3,
            "retry_delay": 1000,
            "exponential_backoff": true
          }
        }
      },
      
      {
        "system_id": "google_drive",
        "name": "Google Drive Integration",
        "enabled": true,
        "status": "ACTIVE",
        "priority": "HIGH",
        "description": "Document storage and template management",
        "api_endpoints": [
          {
            "endpoint_id": "drive_files_upload",
            "method": "POST",
            "internal_path": "/api/drive/upload",
            "external_url": "https://www.googleapis.com/upload/drive/v3/files",
            "purpose": "File upload to Google Drive",
            "data_mapping": {
              "request": {
                "name": "file_name",
                "parents": "folder_id",
                "file": "file_data"
              },
              "response": {
                "id": "file_id",
                "name": "file_name",
                "webViewLink": "file_url",
                "webContentLink": "download_url"
              }
            },
            "authentication": {
              "type": "oauth2",
              "header": "Authorization",
              "key": "Bearer GOOGLE_ACCESS_TOKEN"
            }
          },
          {
            "endpoint_id": "drive_files_download",
            "method": "GET",
            "internal_path": "/api/drive/download",
            "external_url": "https://www.googleapis.com/drive/v3/files/{fileId}",
            "purpose": "File download from Google Drive",
            "data_mapping": {
              "request": {
                "fileId": "file_id",
                "alt": "media"
              },
              "response": {
                "file_content": "binary_data",
                "file_metadata": "file_info"
              }
            },
            "authentication": {
              "type": "oauth2",
              "header": "Authorization",
              "key": "Bearer GOOGLE_ACCESS_TOKEN"
            }
          },
          {
            "endpoint_id": "drive_folders_list",
            "method": "GET",
            "internal_path": "/api/drive/folders",
            "external_url": "https://www.googleapis.com/drive/v3/files",
            "purpose": "List folders in Google Drive",
            "data_mapping": {
              "request": {
                "q": "query_parameters",
                "fields": "fields_to_return"
              },
              "response": {
                "files": "folder_list",
                "nextPageToken": "pagination_token"
              }
            },
            "authentication": {
              "type": "oauth2",
              "header": "Authorization",
              "key": "Bearer GOOGLE_ACCESS_TOKEN"
            }
          }
        ],
        "data_transformations": [
          {
            "transformation_id": "drive_file_transform",
            "description": "Transform file data for Google Drive",
            "input_format": "internal_file_format",
            "output_format": "drive_file_format",
            "rules": [
              {
                "field": "file_name",
                "rule": "sanitize_filename",
                "input": "Customer Document #123.pdf",
                "output": "customer_document_123.pdf"
              },
              {
                "field": "folder_path",
                "rule": "convert_to_folder_id",
                "input": "/customers/2024/01",
                "output": "FOLDER_ID_HERE"
              }
            ]
          }
        ],
        "error_handling": {
          "error_codes": {
            "400": "Bad Request - Invalid file format",
            "401": "Unauthorized - Invalid OAuth token",
            "403": "Forbidden - Insufficient permissions",
            "404": "Not Found - File not found",
            "429": "Too Many Requests - Rate limit exceeded"
          },
          "retry_logic": {
            "max_retries": 3,
            "retry_delay": 2000,
            "exponential_backoff": true
          }
        }
      },
      
