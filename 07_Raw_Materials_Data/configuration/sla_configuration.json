  "escalation_rules": {
    "levels": [
      {
        "level": 1,
        "name": "Team Lead",
        "trigger_threshold_hours": 2,
        "notification_methods": ["email", "internal_notification"],
        "auto_escalate": true,
        "escalation_delay_hours": 4
      },
      {
        "level": 2,
        "name": "Manager",
        "trigger_threshold_hours": 6,
        "notification_methods": ["email", "sms", "internal_notification"],
        "auto_escalate": true,
        "escalation_delay_hours": 8
      },
      {
        "level": 3,
        "name": "Director",
        "trigger_threshold_hours": 12,
        "notification_methods": ["email", "sms", "whatsapp", "internal_notification"],
        "auto_escalate": false,
        "escalation_delay_hours": null
      }
    ],
    "escalation_conditions": {
      " overdue_tasks": true,
      "failed_tasks": true,
      "customer_complaints": true,
      "system_errors": true,
      "critical_issues": true
    }
  },
  
  "monitoring": {
    "real_time_tracking": {
      "enabled": false,
      "update_interval_seconds": 300,
      "dashboard_refresh_seconds": 60,
      "alert_check_interval_seconds": 1800
    },
    "performance_metrics": {
      "enabled": false,
      "metrics_tracked": [
        "task_completion_time",
        "sla_compliance_rate",
        "escalation_frequency",
        "customer_satisfaction",
        "team_performance",
        "system_response_time"
      ]
    },
    "reporting": {
      "enabled": false,
      "report_frequency": "daily",
      "report_types": [
        "sla_compliance_report",
        "escalation_report",
        "performance_report",
        "customer_satisfaction_report",
        "team_productivity_report"
      ]
    }
  },
  
  "sla_definitions": {
    "customer_registration": {
      "name": "Customer Registration SLA",
      "description": "Time to complete customer registration process",
      "start_event": "registration_started",
      "end_event": "registration_completed",
      "target_hours": 24,
      "measurement_unit": "hours",
      "exclusions": ["weekends", "holidays"],
      "owner": "sales_team"
    },
    "document_verification": {
      "name": "Document Verification SLA",
      "description": "Time to verify uploaded documents",
      "start_event": "document_uploaded",
      "end_event": "document_verified",
      "target_hours": 48,
      "measurement_unit": "hours",
      "exclusions": ["holidays"],
      "owner": "document_team"
    },
    "property_booking": {
      "name": "Property Booking SLA",
      "description": "Time to complete property booking process",
      "start_event": "booking_initiated",
      "end_event": "booking_confirmed",
      "target_hours": 72,
      "measurement_unit": "hours",
      "exclusions": [],
      "owner": "sales_team"
    },
    "bank_application": {
      "name": "Bank Application SLA",
      "description": "Time to submit and track bank application",
      "start_event": "application_submitted",
      "end_event": "application_approved",
      "target_hours": 120,
      "measurement_unit": "hours",
      "exclusions": [],
      "owner": "finance_team"
    },
    "loan_approval": {
      "name": "Loan Approval SLA",
      "description": "Time to get loan approval from bank",
      "start_event": "bank_submission",
      "end_event": "loan_approved",
      "target_hours": 168,
      "measurement_unit": "hours",
      "exclusions": [],
      "owner": "finance_team"
    },
    "akad_scheduling": {
      "name": "Akad Scheduling SLA",
      "description": "Time to schedule akad (credit agreement)",
      "start_event": "loan_approved",
      "end_event": "akad_scheduled",
      "target_hours": 48,
      "measurement_unit": "hours",
      "exclusions": ["holidays"],
      "owner": "legal_team"
    },
    "document_generation": {
      "name": "Document Generation SLA",
      "description": "Time to generate required documents",
      "start_event": "document_request",
      "end_event": "document_generated",
      "target_hours": 24,
      "measurement_unit": "hours",
      "exclusions": [],
      "owner": "document_team"
    }
  },
  
