      "immediate_retry": {
        "max_attempts": 2,
        "delay_seconds": 5
      },
      "exponential_backoff": {
        "max_attempts": 5,
        "initial_delay_seconds": 60,
        "backoff_multiplier": 2,
        "max_delay_seconds": 3600
