    {
      "id": 6,
      "name": "Risk Assessment Rules",
      "category": "risk_assessment",
      "description": "Risk assessment and credit scoring rules",
      "rules": [
        {
          "rule_id": "RISK_001",
          "name": "Credit Score Threshold",
          "condition": "credit_score >= 650",
          "description": "Credit score must be 650 or higher",
          "error_message": "Credit score too low for KPR qualification",
          "severity": "critical",
          "validation_type": "credit_score_check",
          "applies_to": ["application", "risk_assessment"]
        },
        {
          "rule_id": "RISK_002",
          "name": "Employment Stability Score",
          "condition": "employment_score >= 60",
          "description": "Employment must be stable (score 60+)",
          "error_message": "Employment not stable enough",
          "severity": "high",
          "validation_type": "stability_check",
          "applies_to": ["application", "risk_assessment"]
        },
        {
          "rule_id": "RISK_003",
          "name": "Income Stability",
          "condition": "income_stable",
          "description": "Income must be stable",
          "error_message": "Income not stable",
          "severity": "high",
          "validation_type": "stability_check",
          "applies_to": ["application", "risk_assessment"]
        },
        {
          "rule_id": "RISK_004",
          "name": "Debt Service Ratio",
          "condition": "debt_service_ratio <= 0.35",
          "description": "Debt service ratio must be 35% or less",
          "error_message": "Debt service ratio too high",
          "severity": "high",
          "validation_type": "ratio_check",
          "applies_to": ["application", "risk_assessment"]
        }
      ],
      "enabled": true,
      "auto_check": true,
      "priority": "high"
    },
