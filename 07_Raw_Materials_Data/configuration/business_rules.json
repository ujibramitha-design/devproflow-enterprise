        "bank_processing",
        "fund_transfer",
        "document_verification",
        "disbursement_release",
        "post_disbursement"
      ],
      "required_rules": ["FIN_001", "FIN_002", "FIN_003", "FIN_004", "FIN_005"],
      "auto_check": true,
      "priority": "high"
    },
    {
      "id": 8,
      "name": "Technical Validation Rules",
      "category": "technical_validation",
      "description": "Technical validation and format checking rules from bramsray3",
      "rules": [
        {
          "rule_id": "TECH_001",
          "name": "Email Format Validation",
          "condition": "email_format_valid",
          "description": "Email must be in valid format",
          "error_message": "Invalid email format",
          "severity": "critical",
          "validation_type": "format_check",
          "applies_to": ["application", "customer_validation"],
          "regex_pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$"
        },
        {
          "rule_id": "TECH_002",
          "name": "Phone Format Validation",
          "condition": "phone_format_valid",
          "description": "Phone number must be valid Indonesian format",
          "error_message": "Invalid Indonesian phone number format",
          "severity": "critical",
          "validation_type": "format_check",
          "applies_to": ["application", "customer_validation"],
          "regex_pattern": "^(\\+62|62)?[\\s-]?0?8[1-9]{1}[\\s-]?\\d{1,4}[\\s-]?\\d{1,4}[\\s-]?\\d{1,4}$"
        },
        {
          "rule_id": "TECH_003",
          "name": "NIK Format Validation",
          "condition": "nik_format_valid",
          "description": "NIK must be 16 digits",
          "error_message": "NIK must be 16 digits",
          "severity": "critical",
          "validation_type": "format_check",
          "applies_to": ["application", "customer_validation"],
          "regex_pattern": "^\\d{16}$"
        },
        {
          "rule_id": "TECH_004",
          "name": "NPWP Format Validation",
          "condition": "npwp_format_valid",
          "description": "NPWP must be in valid format XX.XXX.XXX.X-XXX.XXX",
          "error_message": "NPWP must be in format XX.XXX.XXX.X-XXX.XXX",
          "severity": "critical",
          "validation_type": "format_check",
          "applies_to": ["application", "customer_validation"],
          "regex_pattern": "^\\d{2}\\.\\d{3}\\.\\d{3}\\.\\d-\\d{3}\\.\\d{3}$"
        },
        {
          "rule_id": "TECH_005",
          "name": "Loan Amount Range Validation",
          "condition": "loan_amount_in_range",
          "description": "Loan amount must be between 50 million and 10 billion IDR",
          "error_message": "Loan amount must be between 50 million and 10 billion IDR",
          "severity": "critical",
          "validation_type": "range_check",
          "applies_to": ["application", "financial_validation"],
          "min_value": 50000000,
          "max_value": 10000000000
        },
        {
          "rule_id": "TECH_006",
          "name": "Down Payment Percentage Validation",
          "condition": "down_payment_percentage_valid",
          "description": "Down payment must be at least 20% of loan amount",
          "error_message": "Down payment must be at least 20% of loan amount",
          "severity": "critical",
          "validation_type": "percentage_check",
          "applies_to": ["application", "financial_validation"],
          "min_percentage": 20
        },
        {
          "rule_id": "TECH_007",
          "name": "Tenure Range Validation",
          "condition": "tenure_in_range",
          "description": "Tenure must be between 1-30 years (12-360 months)",
          "error_message": "Tenure must be between 1-30 years",
          "severity": "critical",
          "validation_type": "range_check",
          "applies_to": ["application", "financial_validation"],
          "min_months": 12,
          "max_months": 360
        },
        {
          "rule_id": "TECH_008",
          "name": "File Size Validation",
          "condition": "file_size_valid",
          "description": "File size must not exceed maximum limit",
          "error_message": "File size exceeds maximum limit",
          "severity": "medium",
          "validation_type": "file_check",
          "applies_to": ["application", "document_validation"],
          "max_size_mb": 10
        },
        {
          "rule_id": "TECH_009",
          "name": "File Type Validation",
          "condition": "file_type_allowed",
          "description": "File type must be in allowed list",
          "error_message": "File type not allowed",
          "severity": "medium",
          "validation_type": "file_check",
          "applies_to": ["application", "document_validation"],
          "allowed_types": ["pdf", "jpg", "jpeg", "png", "doc", "docx"]
        }
      ],
      "enabled": true,
      "auto_check": true,
      "priority": "high"
    },
    {
      "id": 9,
      "name": "System Configuration Rules",
      "category": "system_configuration",
      "description": "System configuration and feature toggle rules from bramsray3",
      "rules": [
        {
          "rule_id": "SYS_001",
          "name": "Customer Management Feature",
          "condition": "feature_customer_management_enabled",
          "description": "Customer management feature must be enabled",
          "error_message": "Customer management feature is disabled",
          "severity": "high",
          "validation_type": "feature_check",
          "applies_to": ["system", "feature_validation"],
          "feature_name": "customer_management",
          "required_status": "ACTIVE"
        },
        {
          "rule_id": "SYS_002",
          "name": "Unit Management Feature",
          "condition": "feature_unit_management_enabled",
          "description": "Unit management feature must be enabled",
          "error_message": "Unit management feature is disabled",
          "severity": "high",
          "validation_type": "feature_check",
