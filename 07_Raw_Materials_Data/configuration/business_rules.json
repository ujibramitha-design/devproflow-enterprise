  "validation_workflows": [
    {
      "workflow_id": "WF_001",
      "name": "Customer Onboarding",
      "description": "Customer data collection and initial validation",
      "steps": [
        "customer_data_collection",
        "initial_validation",
        "document_upload",
        "preliminary_assessment",
        "credit_check",
        "compliance_check"
