  "description": "Complete business rules and validation logic for KPRFlow Enterprise",
  "business_rules": [
    {
      "id": 1,
      "name": "Customer Eligibility Rules",
      "category": "customer_validation",
      "description": "Customer eligibility criteria for KPR applications",
      "rules": [
        {
          "rule_id": "CUST_001",
          "name": "Minimum Age Requirement",
          "condition": "age >= 19",
          "description": "Customer must be at least 19 years old (BTN Bank only)",
          "error_message": "Customer must be at least 19 years old (BTN Bank only)",
          "severity": "critical",
          "validation_type": "age_check",
          "applies_to": ["application", "customer_validation"],
          "bank_specific": "BTN"
        },
        {
          "rule_id": "CUST_002",
          "name": "Maximum Age Requirement",
          "condition": "age <= 55",
          "description": "Customer must not be older than 55 years old",
          "error_message": "Customer age must be 55 years or younger",
          "severity": "critical",
          "validation_type": "age_check",
          "applies_to": ["application", "customer_validation"]
        },
        {
          "rule_id": "CUST_003",
          "name": "Minimum Income Requirement",
          "condition": "monthly_income >= 2500000",
          "description": "Customer minimum monthly income 2.5 million rupiah",
          "error_message": "Customer must have minimum income of 2.5 million rupiah per month",
          "severity": "critical",
          "validation_type": "income_check",
          "applies_to": ["application", "customer_validation"]
        },
        {
          "rule_id": "CUST_004",
          "name": "Credit Score Minimum",
          "condition": "credit_score >= 650",
          "description": "Customer must have minimum credit score of 650",
          "error_message": "Credit score must be at least 650",
          "severity": "critical",
          "validation_type": "credit_check",
          "applies_to": ["application", "customer_validation"]
        },
        {
          "rule_id": "CUST_005",
          "name": "Employment Stability",
          "condition": "employment_months >= 12",
          "description": "Customer must have stable employment for at least 1 year",
          "error_message": "Customer must have stable employment for at least 1 year",
          "severity": "high",
          "validation_type": "employment_check",
          "applies_to": ["application", "customer_validation"]
        }
      ],
      "required_documents": [
        "ID card",
        "Family card",
        "Salary slip",
        "Bank statement",
        "Tax return",
        "Marriage certificate"
      ],
      "enabled": true,
      "auto_check": true,
      "priority": "high"
    },
    {
      "id": 2,
      "name": "Property Validation Rules",
      "category": "property_validation",
      "description": "Property validation and requirements for KPR applications",
      "rules": [
        {
          "rule_id": "PROP_001",
          "name": "Property Type Validation",
          "condition": "property_type in ['Rumah Tinggal', 'Rumah Subsidi', 'Ruko']",
          "description": "Property type must be valid KPR property type",
          "error_message": "Invalid property type for KPR financing",
          "severity": "critical",
          "validation_type": "property_type_check",
          "applies_to": ["application", "property_validation"]
        }
      ],
      "property_types": [
        {
          "property_type": "Rumah Tinggal",
          "min_price": 500000000,
          "max_price": 5000000000,
          "min_area": 36,
          "max_area": 200,
          "features": ["2 bedrooms", "1 bathroom", "carport"],
          "requirements": ["Legal certificate", "Building permit"]
        },
        {
          "property_type": "Rumah Subsidi",
          "min_price": 150000000,
          "max_price": 1000000000,
          "min_area": 21,
          "max_area": 70,
          "features": ["2 bedrooms", "1 bathroom"],
          "requirements": ["Legal certificate", "Building permit", "Subsidy approval"]
        },
        {
          "property_type": "Ruko",
          "min_price": 800000000,
          "max_price": 8000000000,
          "min_area": 60,
          "max_area": 200,
          "features": ["Commercial space", "Storage", "Parking"],
          "requirements": ["Legal certificate", "Building permit", "Business license"]
        }
      ],
      "enabled": true,
      "auto_check": true,
      "priority": "high"
    },
    {
      "id": 3,
      "name": "Financial Validation Rules",
      "category": "financial_validation",
      "description": "Financial validation and assessment rules for KPR applications",
      "rules": [
        {
          "rule_id": "FIN_001",
          "name": "Interest Rate Limit",
          "condition": "interest_rate >= 6.5 && interest_rate <= 11.5",
          "description": "Interest rate must be between 6.5% and 11.5%",
          "error_message": "Interest rate must be between 6.5% and 11.5%",
          "severity": "critical",
          "validation_type": "interest_rate_check",
          "applies_to": ["application", "financial_validation"]
        },
        {
          "rule_id": "FIN_002",
          "name": "Loan to Value Ratio",
          "condition": "loan_amount <= 0.8 * property_value",
          "description": "Loan amount cannot exceed 80% of property value",
          "error_message": "Loan amount exceeds 80% of property value",
          "severity": "critical",
          "validation_type": "ltv_check",
          "applies_to": ["application", "financial_validation"]
        },
        {
          "rule_id": "FIN_003",
          "name": "Debt to Income Ratio",
          "condition": "monthly_payment <= 0.3 * monthly_income",
          "description": "Monthly payment cannot exceed 30% of monthly income",
          "error_message": "Monthly payment exceeds 30% of monthly income",
          "severity": "critical",
          "validation_type": "dti_check",
          "applies_to": ["application", "financial_validation"]
        },
        {
          "rule_id": "FIN_004",
          "name": "Down Payment Percentage",
          "condition": "down_payment >= 0.1 * property_value",
          "description": "Minimum down payment of 10% of property value",
          "error_message": "Down payment must be at least 10% of property value",
          "severity": "critical",
          "validation_type": "percentage_check",
          "applies_to": ["application", "financial_validation"]
        },
        {
          "rule_id": "FIN_005",
          "name": "Monthly Payment Capacity",
          "condition": "monthly_payment <= 5000000",
          "description": "Monthly payment maximum 5 million rupiah",
          "error_message": "Monthly payment exceeds maximum allowed",
          "severity": "high",
          "validation_type": "amount_check",
          "applies_to": ["application", "financial_validation"]
        }
      ],
      "enabled": true,
      "auto_check": true,
      "priority": "high"
    },
