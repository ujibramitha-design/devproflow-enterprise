      "VAL004": "Range validation error",
      "VAL005": "Uniqueness validation error",
      "VAL006": "Business rule validation error",
      "VAL007": "System validation error"
    },
    "error_severity": {
      "critical": "Block processing",
      "high": "Manual review required",
      "medium": "Warning notification",
      "low": "Info log"
    }
  },
  
  "integration_mapping": {
    "technical_validation": {
      "source": "packages/utils/src/validation.ts",
      "functions": [
        "isValidEmail",
        "isValidPhone", 
        "isValidNIK",
        "isValidNPWP",
        "isValidAmount",
        "isValidLoanAmount",
        "isValidDownPayment",
        "isValidTenure",
        "isValidFileSize",
        "isValidFileType"
      ]
    },
    "database_validation": {
