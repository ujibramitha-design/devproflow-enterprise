{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/02_Web_Application/backend/index.js"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "api.devproflow.com" }],
      "destination": "/02_Web_Application/backend/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/02_Web_Application/frontend/$1"
    }
  ]
}
