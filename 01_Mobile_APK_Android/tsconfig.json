{
  "extends": "@tsconfig/react-native/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-native",
    "lib": ["es2022"],
    "moduleResolution": "node",
    "noEmit": true,
    "strict": true,
    "target": "es2022",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../06_Shared_Components/*"],
      "@design-system/*": ["./src/theme/*"],
      "@components/*": ["./src/components/*"],
      "@screens/*": ["./src/screens/*"],
      "@navigation/*": ["./src/navigation/*"],
      "@utils/*": ["./src/utils/*"],
      "@providers/*": ["./src/providers/*"],
      "@/ds-tokens": ["../05_UI_Design_System/Shared/Design_Tokens.json"]
    }
  },
  "include": [
    "src/**/*",
    "../06_Shared_Components/**/*"
  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js"
  ]
}
